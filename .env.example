# BSC Arbitrage Bot — Environment Configuration
# Copy this to .env and fill in your values

# BSC RPC Endpoint (required)
# Public: https://bsc-dataseed1.binance.org
# Private (recommended): Get from QuickNode, Blast, or Ankr
RPC_URL=https://bsc-dataseed1.binance.org

# Your wallet private key (required)
# WARNING: Never share this. Use a dedicated wallet with limited funds.
TRADER_PRIVATE_KEY=

# Gas settings
MAX_GAS_PRICE_GWEI=5
MIN_PROFIT_BNB=0.001

# Safe mode: true = estimate only, false = real trades
DRY_RUN=true
